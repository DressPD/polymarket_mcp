# ==========================================================
# polymarket_mcp environment template
# Copy this file to `.env` and fill values.
# Keep `.env` private. Never commit secrets.
# ==========================================================

# -------------------------
# Runtime behavior
# -------------------------
BOT_POLL_INTERVAL_SECONDS=20
BOT_DRY_RUN=true
BOT_ENABLE_LIVE_TRADING=false
BOT_MAX_USD_PER_BET=5
BOT_MAX_BETS_PER_HOUR=4
BOT_MARKET_LIMIT=50
BOT_MIN_CONFIDENCE=0.65

# -------------------------
# Signal filters
# -------------------------
SIGNAL_KEYWORDS=trump,donald,trump campaign,truth social,white house
SIGNAL_LOOKBACK_MINUTES=60

# Signal service order (comma-separated)
# Available: x, truth_rss, official_rss, newsapi, custom_rss
SIGNAL_SERVICES=x,truth_rss,official_rss

# Optional NewsAPI key
NEWS_API_KEY=

# Optional custom RSS feeds (comma-separated URLs)
CUSTOM_RSS_URLS=

# Market service order (comma-separated)
# Available: gamma
MARKET_SERVICES=gamma

# MCP tool limits
MCP_DEFAULT_LIMIT=10
MCP_MAX_LIMIT=50

# -------------------------
# X (Twitter) API
# Get bearer token from:
# https://developer.x.com/en/portal/dashboard
# Create app/project and enable API access.
# -------------------------
X_BEARER_TOKEN=

# -------------------------
# Polymarket public endpoints
# -------------------------
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# -------------------------
# Polymarket trading identity
# PRIVATE_KEY: exported wallet private key used for signing.
# FUNDER_ADDRESS: wallet/funder address associated with that key.
# SIGNATURE_TYPE:
#   0 = EOA
#   1 = POLY_PROXY
#   2 = GNOSIS_SAFE
# Docs:
# https://docs.polymarket.com/developers/CLOB/authentication
# -------------------------
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=1

# -------------------------
# Optional pre-generated Polymarket L2 API creds
# If empty, client may derive creds from private key.
# Docs:
# https://docs.polymarket.com/developers/CLOB/authentication
# -------------------------
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# -------------------------
# Live-trading hard gate checklist
# 1) BOT_DRY_RUN=false
# 2) BOT_ENABLE_LIVE_TRADING=true
# 3) POLYMARKET_PRIVATE_KEY set
# 4) POLYMARKET_FUNDER_ADDRESS set
# -------------------------
